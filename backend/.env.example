# Copy to .env for local dev (uvicorn api.index:app --reload).
# On Vercel, set these in Project → Settings → Environment Variables.

# Supabase (Project Settings → API)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# PayPal (developer.paypal.com → My Apps & Credentials)
# Use https://api-m.sandbox.paypal.com while testing, then switch to live.
PAYPAL_API_BASE=https://api-m.sandbox.paypal.com
PAYPAL_CLIENT_ID=...
PAYPAL_CLIENT_SECRET=...
PAYPAL_WEBHOOK_ID=...

# SMTP for license key delivery (Gmail: use an App Password, not your password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=you@gmail.com
SMTP_PASS=your-app-password
FROM_EMAIL=you@gmail.com

# AI — Hugging Face Inference Providers (free tier)
# Create a token: huggingface.co → Settings → Access Tokens →
#   Fine-grained → enable "Make calls to Inference Providers"
HF_TOKEN=hf_...
# Any chat model on the HF router works. Cheaper fallback if credits run low:
#   meta-llama/Llama-3.1-8B-Instruct
MODEL_ID=Qwen/Qwen2.5-72B-Instruct
